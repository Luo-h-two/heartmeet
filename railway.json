{
  "$schema": "https://railway.app/railway.schema.json",
  "rootDirectory": "backend",
  "build": {
    "command": "pip install -r requirements.txt",
    "watchPatterns": ["**/*.py", "**/*.html", "**/*.js", "**/*.css", "**/*.json"]
  },
  "start": {
    "command": "uvicorn main:app --host 0.0.0.0 --port $PORT",
    "port": 8000
  }
}